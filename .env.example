# Copia este archivo a ".env" y completa tus valores. Nunca subas el ".env" real a un repositorio público.

# Tu clave de API de Anthropic (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=tu_clave_aqui

# Contraseña de acceso a la herramienta (opcional, pero recomendada si el enlace es público)
APP_PASSWORD=elige_una_contraseña

# Puerto local (la mayoría de los servicios de hosting lo asignan ellos automáticamente)
PORT=3000
